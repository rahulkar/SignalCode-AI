<idea-plugin>
    <id>com.signalcode.mvp</id>
    <name>SignalCode AI</name>
    <vendor>SignalCode AI</vendor>
    <description>SignalCode AI agent workspace for guided edits, file creation, and telemetry-aware coding workflows.</description>

    <depends>com.intellij.modules.platform</depends>
    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="SignalCodeNotifications" displayType="BALLOON" isLogByDefault="true"/>
        <postStartupActivity implementation="com.signalcode.mvp.IdeTelemetryStartupActivity"/>
    </extensions>

    <actions>
        <action id="SignalCodeInlineAction"
                class="com.signalcode.mvp.SignalCodeInlineAction"
                text="SignalCode AI"
                description="Open SignalCode AI">
            <keyboard-shortcut keymap="$default" first-keystroke="alt BACK_SLASH"/>
            <keyboard-shortcut keymap="$default" first-keystroke="control alt K"/>
        </action>
    </actions>
</idea-plugin>
